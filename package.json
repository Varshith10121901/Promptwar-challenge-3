{
  "name": "carbon-footprint-platform",
  "version": "1.0.0",
  "description": "AI-powered Carbon Footprint Awareness Platform",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "test": "jest --coverage --runInBand",
    "test:unit": "jest --testPathPattern=server/__tests__/unit",
    "test:integration": "jest --testPathPattern=server/__tests__/integration --runInBand",
    "lint": "eslint server.js server/ public/js/"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "node-cache": "^5.1.2",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/server/__tests__/"
    ]
  },
  "overrides": {
    "js-yaml": "^4.1.2"
  }
}
